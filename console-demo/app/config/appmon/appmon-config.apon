# Polling configuration used only when WebSocket is not supported
pollingConfig: {
    # The interval in milliseconds at which the client polls the server for new messages
    pollingInterval: 3000
    # The duration in milliseconds after which an inactive polling session expires
    sessionTimeout: 30000
}
counterPersistInterval: 5
app: {
    id: console
    group: group1
    title: Console
    event: {
        id: activity
        target: console
        parameters: {
            +: /**
            -: /nodes/**/appmon/polling/**  # Ignore polling requests
        }
    }
    event: {
        id: session
        target: tow.server/console
    }
    metric: {
        id: heap
        title: Heap
        description: Shows JVM Heap memory usage status
        reader: com.aspectran.aspectow.appmon.engine.exporter.metric.jvm.HeapMemoryUsageReader
        sampleInterval: 500
        heading: true
    }
    metric: {
        id: undertow-tp
        title: Undertow TP
        description: Metrics of Undertow thread pool resources
        reader: com.aspectran.aspectow.appmon.engine.exporter.metric.undertow.NioWorkerMetricsReader
        target: tow.server
        sampleInterval: 500
        heading: true
    }
    log: {
        id: app
        file: console.log
        sampleInterval: 300
        lastLines: 100
    }
    log: {
        id: access
        file: console-access.log
        sampleInterval: 300
        lastLines: 100
    }
}
app: {
    id: root
    group: group2
    title: Root
    event: {
        id: activity
        target: root
        parameters: {
            +: /**
            -: /nodes/**/appmon/polling/**  # Ignore polling requests
        }
    }
    event: {
        id: session
        target: tow.server/root
    }
    log: {
        id: app
        file: root.log
        sampleInterval: 300
        lastLines: 30
    }
    log: {
        id: access
        file: root-access.log
        sampleInterval: 300
        lastLines: 60
    }
}
