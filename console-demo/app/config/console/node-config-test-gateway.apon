# Cluster-wide settings
cluster: {
    id: cluster1
    mode: gateway  # direct or gateway or autoscaling
    scheduler: {
        releasedOnUnlock: false
    }
}
group: {
    id: group1
    title: Group 1
    description: This is group 1
}
group: {
    id: group2
    title: Group 2
    description: This is group 2
}
node: {
    id: node1
    group: group1
    title: Node-1
    port: 8082
    endpoint: {
        mode: auto
    }
}
node: {
    id: node2
    group: group2
    title: Node-2
    port: 8092
    endpoint: {
        mode: auto
    }
}
node: {
    id: node3
    group: group2
    title: Node-3
    port: 8083
    endpoint: {
        mode: auto
    }
}
